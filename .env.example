# avwx.rest API token — https://account.avwx.rest
# When set, METAR data is fetched directly from avwx.rest (no CORS proxy needed).
# Falls back to aviationweather.gov if absent or if the request fails.
#
# For local development: copy this file to .env.local and fill in your token.
#   (.env.local is gitignored by *.local)
#
# For GitHub Pages deployment: add AVWX_TOKEN as a repository secret at
#   Settings → Secrets and variables → Actions → New repository secret
VITE_AVWX_TOKEN=your_token_here

# Upstash Redis (Vercel deployment — auto-populated by the Upstash integration)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Self-hosted Redis (Railway / local dev — optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379
