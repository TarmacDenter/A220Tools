# Upstash Redis (Vercel deployment — auto-populated by the Upstash integration)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job secret — must match CRON_SECRET set in Vercel project env vars
# Used to authenticate Vercel's cron calls to /api/internal/prune-hits
CRON_SECRET=

# Self-hosted Redis (local dev — optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379
